NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-me

# SMTP settings for passwordless magic links (NextAuth Email provider)
EMAIL_SERVER_HOST=smtp.example.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=your-smtp-username
EMAIL_SERVER_PASSWORD=your-smtp-password
# Set to true only if your SMTP supports TLS on the chosen port (e.g., 465)
EMAIL_SERVER_SECURE=false
EMAIL_FROM=info@yourexitplans.com

# n8n Webhook URL for idea validation form
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/idea-validation

# Admin Authentication (CHANGE THESE IN PRODUCTION!)
ADMIN_EMAIL=admin@yourexitplans.com
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_PASSWORD_HASH=$2b$10$example-hash-replace-with-real-bcrypt-hash
ADMIN_JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=900000

# For Postie (local testing), you can use:
# EMAIL_SERVER_HOST=localhost
# EMAIL_SERVER_PORT=2525
# EMAIL_SERVER_USER=
# EMAIL_SERVER_PASSWORD=
# EMAIL_SERVER_SECURE=false
# EMAIL_FROM=login@localhost.test
